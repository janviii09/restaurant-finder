# ─── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ───────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/restaurant-finder?retryWrites=true&w=majority

# ─── JWT Secrets ─────────────────────────────────────────
JWT_SECRET=a_long_random_string_min_32_chars

# ─── Upstash Redis ──────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://<name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# ─── CORS / Deployment ──────────────────────────────────
CLIENT_URL=http://localhost:5173
