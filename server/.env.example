# ─── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ───────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/restaurant-finder?retryWrites=true&w=majority

# ─── JWT Secrets ─────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-token-secret-here
JWT_REFRESH_SECRET=your-refresh-token-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Redis (Upstash) ────────────────────────────────────
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:6379

# ─── CORS / Deployment ──────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Cloudinary ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── SendGrid ───────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@restaurantfinder.app

# ─── Web Push (VAPID) ───────────────────────────────────
# Run `node scripts/generateVapid.js` to auto-generate these
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@restaurantfinder.app
